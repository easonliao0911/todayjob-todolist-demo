# 雲端資料庫（Turso）
# 本機開發不需要設定，預設使用 data/today-job-to-do-list.db
# 上 Vercel 時必填
LIBSQL_URL=libsql://your-database-name.turso.io
LIBSQL_AUTH_TOKEN=your_turso_auth_token

# 網站存取保護（Basic Auth）
# 兩個都填才會啟用，任一為空則直接放行（本機開發模式）
BASIC_AUTH_USER=your_username
BASIC_AUTH_PASS=your_password

# Email 通知（Resend）
# 第三版整合 Email 功能時才需要填
RESEND_API_KEY=re_your_resend_api_key
